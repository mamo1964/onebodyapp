# ============================================================
# Environment Variables – copy to .env.local and fill in
# ============================================================

# --- Chatwork (currently hardcoded in app/api/submit/route.ts) ---
# CHATWORK_API_TOKEN=your_token_here
# CHATWORK_ROOM_ID=your_room_id_here

# --- Supabase (for production slot storage) ---
# TODO: When migrating from fs-based slots to Supabase:
#   1. Create a "slots" table with columns: id, label, booked
#   2. Replace readSlots/writeSlots in app/api/slots/route.ts and app/api/submit/route.ts
#      with Supabase client calls
#   3. Uncomment and fill in the variables below
#
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
